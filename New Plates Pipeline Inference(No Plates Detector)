turn text\n","    NO PLATE DETECTION STAGE\n","    \"\"\"\n","\n","    # Load image\n","    image = cv2.imread(image_path)\n","    if image is None:\n","        print(f\"❌ Failed to load: {image_path}\")\n","        return None, 0, None\n","\n","    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n","\n","    # DETECT CHARACTERS DIRECTLY ON FULL IMAGE (NO PLATE DETECTION)\n","    print(\"\\n🔍 Detecting characters on FULL IMAGE (no plate detection)...\")\n","    char_results = char_detector(image_path, conf=0.25, verbose=False)\n","\n","    if len(char_results[0].boxes) == 0:\n","        print(\"   ❌ No characters detected\")\n","        return None, 0, image_rgb\n","\n","    print(f\"   ✅ {len(char_results[0].boxes)} characters detected\")\n","\n","    # Extract character bboxes\n","    char_detections = []\n","    for box in char_results[0].boxes:\n","        x1c, y1c, x2c, y2c = map(int, box.xyxy[0].cpu().numpy())\n","        char_detections.append({\n","            'bbox': [x1c, y1c, x2c, y2c],\n","            'conf': float(box.conf[0]),\n","            'x_center': (x1c + x2c) / 2,\n","            'y_center': (y1c + y2c) / 2\n","        })\n","\n","    # Sort characters by x-coordinate (left to right)\n","    char_detections.sort(key=lambda x: x['x_center'])\n","\n","    print(f\"   📐 Characters sorted by position\")\n","\n","    # CLASSIFY CHARACTERS\n","    print(\"\\n🔤 Classifying characters...\")\n","\n","    recognized_chars = []\n","    confidences = []\n","\n","    for i, char_det in enumerate(char_detections):\n","        x1c, y1c, x2c, y2c = char_det['bbox']\n","\n","        # Crop character from FULL IMAGE\n","        char_crop = image_rgb[y1c:y2c, x1c:x2c]\n","\n","        if char_crop.size == 0:\n","            print(f\"   ⚠️ Char {i+1}: Invalid crop\")\n","            continue\n","\n","        # Convert to PIL\n","        char_pil = Image.fromarray(char_crop)\n","\n","        # Apply transform\n","        char_tensor = classifier_transform(char_pil).unsqueeze(0).to(device)\n","\n","        # Classify\n","        with torch.no_grad():\n","            output = resnet_model(char_tensor)\n","            probs = torch.softmax(output, dim=1)\n","            conf, pred = torch.max(probs, 1)\n","\n","            pred_class = class_names[pred.item()]\n","            pred_conf = conf.item()\n","\n","        recognized_chars.append(pred_class)\n","        confidences.append(pred_conf)\n","\n","        print(f\"   Char {i+1}: '{pred_class}' ({pred_conf:.3f}) at [{x1c},{y1c}]\")\n","\n","    if len(recognized_chars) == 0:\n","        print(\"\\n❌ No characters recognized\")\n","        return None, 0, image_rgb\n","\n","    # Combine results\n","    text = ' '.join(recognized_chars)\n","    avg_conf = np.mean(confidences)\n","\n","    print(f\"\\n✅ RESULT: '{text}' ({avg_conf:.3f})\")\n","\n","    # VISUALIZATION\n","    if visualize:\n","        # Download Arabic font\n","        font_path = '/content/arabic_font.ttf'\n","        if not os.path.exists(font_path):\n","            print(\"\\n📥 Downloading Arabic font...\")\n","            !wget -q -O /content/arabic_font.ttf https://github.com/google/fonts/raw/main/ofl/amiri/Amiri-Regular.ttf\n","\n","        vis_pil = Image.fromarray(image_rgb)\n","        draw = ImageDraw.Draw(vis_pil)\n","\n","        try:\n","            font_char = ImageFont.truetype(font_path, 20)\n","        except:\n","            font_char = ImageFont.load_default()\n","\n","        # Draw character bboxes directly on full image\n","        for i, char_det in enumerate(char_detections):\n","            x1c, y1c, x2c, y2c = char_det['bbox']\n","\n","            # Character bbox (blue - to distinguish from two-stage)\n","            draw.rectangle([x1c, y1c, x2c, y2c], outline=(0, 0, 255), width=2)\n","\n","            # Character label\n","            if i < len(recognized_chars):\n","                char_text = recognized_chars[i]\n","                text_pos = (x1c + 1, max(3, y1c - 25))\n","\n","                # Background\n","                text_bbox = draw.textbbox(text_pos, char_text, font=font_char)\n","                padding = 3\n","                bg_bbox = [\n","                    text_bbox[0] - padding,\n","                    text_bbox[1] - padding,\n","                    text_bbox[2] + padding,\n","                    text_bbox[3] + padding\n","                ]\n","                draw.rectangle(bg_bbox, fill=(255, 255, 255))\n","\n","                # Text\n","                draw.text(text_pos, char_text, fill=(0, 0, 255), font=font_char)\n","\n","        vis = np.array(vis_pil)\n","\n","        # SAVE\n","        if save_result and output_folder:\n","            os.makedirs(output_folder, exist_ok=True)\n","\n","            input_name = os.path.basename(image_path)\n","            name_without_ext = os.path.splitext(input_name)[0]\n","            output_name = f\"{name_without_ext}_single_stage.jpg\"\n","            output_path = os.path.join(output_folder, output_name)\n","\n","            vis_bgr = cv2.cvtColor(vis, cv2.COLOR_RGB2BGR)\n","            cv2.imwrite(output_path, vis_bgr)\n","            print(f\"\\n💾 Saved: {output_path}\")\n","\n","        return text, avg_conf, vis\n","\n","    return text, avg_conf, None\n","\n","print(\"✅ Single-stage pipeline ready\")\n","print(\"=\"*60)"],"metadata":{"id":"atX59RBHV1bN","executionInfo":{"status":"ok","timestamp":1769365327522,"user_tz":-120,"elapsed":18,"user":{"displayName":"","userId":""}},"outputId":"685b5bbe-5bd3-4b67-e72a-2953436a8a36","colab":{"base_uri":"https://localhost:8080/"}},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","🔧 DEFINING SINGLE-STAGE PIPELINE\n","============================================================\n","✅ Single-stage pipeline ready\n","============================================================\n"]}]},{"cell_type":"markdown","source":["**Cell 4: Single I