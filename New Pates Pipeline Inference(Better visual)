ms.ToTensor(),\n","    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n","])\n","\n","print(\"\\n✅ ALL MODELS LOADED!\")\n","print(\"=\"*60)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"v6js1F_riIbG","executionInfo":{"status":"ok","timestamp":1769382091196,"user_tz":-120,"elapsed":13320,"user":{"displayName":"hussien betiti","userId":"02930333267237275373"}},"outputId":"1c05cebd-9cee-4165-b5fd-2369b3e070df"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","📦 LOADING MODELS\n","============================================================\n","\n","1️⃣ Loading Plate Detector...\n","   ✅ Loaded\n","\n","2️⃣ Loading Character Detector...\n","   ✅ Loaded\n","\n","3️⃣ Loading Class Names...\n","   ✅ 27 classes\n","   First 10: ['أ', 'ب', 'ج', 'د', 'ر', 'س', 'ص', 'ط', 'ع', 'ف']\n","\n","4️⃣ Loading ResNet50...\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/torchvision/models/_utils.py:208: UserWarning: The parameter 'pretrained' is deprecated since 0.13 and may be removed in the future, please use 'weights' instead.\n","  warnings.warn(\n","/usr/local/lib/python3.12/dist-packages/torchvision/models/_utils.py:223: UserWarning: Arguments other than a weight enum or `None` for 'weights' are deprecated since 0.13 and may be removed in the future. The current behavior is equivalent to passing `weights=None`.\n","  warnings.warn(msg)\n"]},{"output_type":"stream","name":"stdout","text":["   ✅ Loaded\n","\n","✅ ALL MODELS LOADED!\n","============================================================\n"]}]},{"cell_type":"markdown","source":["**Cell 3: Define Complete Pipeline Function**"],"metadata":{"id":"e4Jb_VGTN8KS"}},{"cell_type":"code","source":["print(\"=\"*60)\n","print(\"🔧 DEFINING PIPELINE\")\n","print(\"=\"*60)\n","\n","def recognize_plate(image_path, visualize=True, save_result=False, output_folder=None):\n","    \"\"\"Full pipeline: Plate → Characters → Text\"\"\"\n","\n","    # Load image\n","    image = cv2.imread(image_path)\n","    if image is None:\n","        print(f\"❌ Failed to load: {image_path}\")\n","        return None, 0, None\n","\n","    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n","\n","    # STEP 1: DETECT PLATE\n","    print(\"\\n1️⃣ Detecting plate...\")\n","    plate_results = plate_detector(image_path, conf=0.25, verbose=False)\n","\n","    if len(plate_results[0].boxes) == 0:\n","        print(\"   ❌ No plate detected\")\n","        return None, 0, image_rgb\n","\n","    plate_box = plate_results[0].boxes[0]\n","    x1, y1, x2, y2 = map(int, plate_box.xyxy[0].cpu().numpy())\n","    plate_conf = float(plate_box.conf[0])\n","\n","    print(f\"   ✅ Plate found (conf: {plate_conf:.3f})\")\n","\n","    # Crop plate\n","    plate_crop = image_rgb[y1:y2, x1:x2]\n","    if plate_crop.size == 0:\n","        print(\"   ❌ Invalid crop\")\n","        return None, 0, image_rgb\n","\n","    # STEP 2: DETECT CHARACTERS\n","    print(\"\\n2️⃣ Detecting characters...\")\n","    temp_path = '/content/temp_plate.png'\n","    cv2.imwrite(temp_path, cv2.cvtColor(plate_crop, cv2.COLOR_RGB2BGR))\n","\n","    char_results = char_detector(temp_path, conf=0.25, verbose=False)\n","\n","    if len(char_results[0].boxes) == 0:\n","        print(\"   ❌ No characters detected\")\n","        return None, 0, image_rgb\n","\n","    print(f\"   ✅ {len(char_results[0].boxes)} characters found\")\n","\n","    # Extract & sort characters\n","    char_detections = []\n","    for box in char_results[0].boxes:\n","        x1c, y1c, x2c, y2c = map(int, box.xyxy[0].cpu().numpy())\n","        char_detections.append({\n","            'bbox': [x1c, y1c, x2c, y2c],\n","            'conf': float(box.conf[0]),\n","            'x_center': (x1c + x2c) / 2\n","        })\n","\n","    char_detections.sort(key=lambda x: x['x_center'])\n","\n","    # STEP 3: CLASSIFY CHARACTERS\n","    print(\"\\n3️⃣ Classifying...\")\n","\n","    recognized_chars = []\n","    confidences = []\n","\n","    for i, char_det in enumerate(char_detections):\n","        x1c, y1c, x2c, y2c = char_det['bbox']\n","        char_crop = plate_crop[y1c:y2c, x1c:x2c]\n","\n","        if char_crop.size == 0:\n","            continue\n","\n","        char_pil = Image.fromarray(char_crop)\n","        char_tensor = classifier_transform(char_pil).unsqueeze(0).to(device)\n","\n","        with torch.no_grad():\n","            output = resnet_model(char_tensor)\n","            probs = torch.softmax(output, dim=1)\n","            conf, pred = torch.max(probs, 1)\n","\n","            pred_class = classes[pred.item()]\n","            pred_conf = conf.item()\n","\n","        recognized_chars.append(pred_class)\n","        confidences.append(pred_conf)\n","\n","        print(f\"   Char {i+1}: '{pred_class}' ({pred_conf:.3f})\")\n","\n","    if len(recognized_chars) == 0:\n","        print(\"\\n❌ No characters recognized\")\n","        return None, 0, image_rgb\n","\n","    # STEP 4: COMBINE\n","    text = ' '.join(recognized_chars)\n","    avg_conf = np.mean(confidences)\n","\n","    print(f\"\\n✅ RESULT: '{text}' ({avg_conf:.3f})\")\n","\n","    # VISUALIZATION\n","    if visualize:\n","        # Download Arabic font if not exists\n","        font_path = '/content/arabic_font.ttf'\n","        if not os.path.exists(font_path):\n","            print(\"\\n📥 Downloading Arabic font...\")\n","            !wget -q -O /content/arabic_font.ttf https://github.com/google/fonts/raw/main/ofl/amiri/Amiri-Regular.ttf\n","\n","        # Convert to PIL\n","        vis_pil = Image.fromarray(image_rgb)\n","        draw = ImageDraw.Draw(vis_pil)\n","\n","        # Load Arabic font - SMALLER SIZE\n","        try:\n","            font_char = ImageFont.truetype(font_path, 20)  # Reduced from 35 to 20\n","        except:\n","            font_char = ImageFont.load_default()\n","\n","        # Draw plate bbox (green)\n","        draw.rectangle([x1, y1, x2, y2], outline=(0, 255, 0), width=4)\n","\n","        # Draw character bboxes and labels\n","        for i, char_det in enumerate(char_detections):\n","            x1c, y1c, x2c, y2c = char_det['bbox']\n","            x1a = x1 + x1c\n","            y1a = y1 + y1c\n","            x2a = x1 + x2c\n","            y2a = y1 + y2c\n","\n","            # Character bbox (red) - THINNER\n","            draw.rectangle([x1a, y1a, x2a, y2a], outline=(255, 0, 0), width=2)  # Reduced from 3 to 2\n","\n","            # Character label with smaller font\n","            if i < len(recognized_chars):\n","                char_text = recognized_chars[i]\n","                text_pos = (x1a + 1, max(3, y1a - 25))  # Adjusted position for smaller font\n","\n","                # Smaller background\n","                text_bbox = draw.textbbox(text_pos, char_text, font=font_char)\n","                padding = 3  # Reduced from 5 to 3\n","                bg_bbox = [\n","                    text_bbox[0] - padding,\n","                    text_bbox[1] - padding,\n","                    text_bbox[2] + padding,\n","                    text_bbox[3] + padding\n","                ]\n","                draw.rectangle(bg_bbox, fill=(255, 255, 255))\n","\n","                # Character text\n","                draw.text(text_pos, char_text, fill=(255, 0, 0), font=font_char)\n","\n","        # Convert back to numpy (NO GREEN BOX ADDED)\n","        vis = np.array(vis_pil)\n","\n","        # SAVE RESULT\n","        if save_result and output_folder:\n","            os.makedirs(output_folder, exist_ok=True)\n","\n","            input_name = os.path.basename(image_path)\n","            name_without_ext = os.path.splitext(input_name)[0]\n","            output_name = f\"{name_without_ext}_result.jpg\"\n","            output_path = os.path.join(output_folder, output_name)\n","\n","            vis_bgr = cv2.cvtColor(vis, cv2.COLOR_RGB2BGR)\n","       